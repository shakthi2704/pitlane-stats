//   provider = "prisma-client"
//   output   = "../lib/generated/prisma"
// }

// generator client {
//   provider = "prisma-client-js"
// }

generator client {
  provider        = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}

// ─── Sync tracking ──────────────────────────────────────────────────────────
model SyncLog {
  id        Int       @id @default(autoincrement())
  sport     String
  dataType  String
  season    String
  round     String?
  syncedAt  DateTime  @default(now())
  success   Boolean   @default(true)
  error     String?

  @@index([sport, dataType, season])
  @@index([syncedAt])
  @@map("sync_logs")
}

// ─── F1 Reference Data ──────────────────────────────────────────────────────
model F1Driver {
  driverId        String  @id
  code            String?
  permanentNumber String?
  givenName       String
  familyName      String
  nationality     String?
  dateOfBirth     String?
  url             String?

  driverStandings F1DriverStanding[]
  raceResults     F1RaceResult[]
  lapTimes        F1LapTime[]

  @@map("f1_drivers")
}

model F1Constructor {
  constructorId String @id
  name          String
  nationality   String?
  url           String?

  constructorStandings F1ConstructorStanding[]
  raceResults          F1RaceResult[]

  @@map("f1_constructors")
}

model F1Circuit {
  circuitId   String @id
  circuitName String
  locality    String?
  country     String?
  lat         String?
  lng         String?
  url         String?

  races F1Race[]

  @@map("f1_circuits")
}

// ─── Season Data ─────────────────────────────────────────────────────────────
model F1DriverStanding {
  id              Int      @id @default(autoincrement())
  season          String
  round           String
  position        Int
  points          Float
  wins            Int
  driverId        String
  driver          F1Driver @relation(fields: [driverId], references: [driverId])
  constructorId   String
  constructorName String
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@unique([season, driverId])
  @@index([season, position])
  @@map("f1_driver_standings")
}

model F1ConstructorStanding {
  id            Int           @id @default(autoincrement())
  season        String
  round         String
  position      Int
  points        Float
  wins          Int
  constructorId String
  constructor   F1Constructor @relation(fields: [constructorId], references: [constructorId])
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  @@unique([season, constructorId])
  @@index([season, position])
  @@map("f1_constructor_standings")
}

model F1Race {
  id        Int       @id @default(autoincrement())
  season    String
  round     Int
  raceName  String
  date      String
  time      String?
  circuitId String
  circuit   F1Circuit @relation(fields: [circuitId], references: [circuitId])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  results   F1RaceResult[]
  lapTimes  F1LapTime[]

  @@unique([season, round])
  @@index([season])
  @@map("f1_races")
}

model F1RaceResult {
  id               Int           @id @default(autoincrement())
  raceId           Int
  race             F1Race        @relation(fields: [raceId], references: [id], onDelete: Cascade)
  position         Int?
  positionText     String
  number           String?
  grid             Int?
  laps             Int?
  status           String?
  points           Float?
  time             String?
  driverId         String
  driver           F1Driver      @relation(fields: [driverId], references: [driverId])
  constructorId    String
  constructor      F1Constructor @relation(fields: [constructorId], references: [constructorId])
  fastestLapRank   Int?
  fastestLapNumber Int?
  fastestLapTime   String?
  fastestLapSpeed  String?
  createdAt        DateTime      @default(now())

  @@unique([raceId, driverId])
  @@index([raceId])
  @@map("f1_race_results")
}

model F1LapTime {
  id        Int      @id @default(autoincrement())
  raceId    Int
  race      F1Race   @relation(fields: [raceId], references: [id], onDelete: Cascade)
  lapNumber Int
  driverId  String
  driver    F1Driver @relation(fields: [driverId], references: [driverId])
  position  Int?
  time      String
  timeMs    Int?

  @@unique([raceId, lapNumber, driverId])
  @@index([raceId, driverId])
  @@index([raceId, lapNumber])
  @@map("f1_lap_times")
}

model F1News {
  id          Int       @id @default(autoincrement())
  title       String
  description String?
  imageUrl    String?
  source      String?
  url         String    @unique
  publishedAt DateTime?
  syncedAt    DateTime  @default(now())

  @@index([publishedAt])
  @@map("f1_news")
}

// ─── MotoGP Reference Data ──────────────────────────────────────────────────

// Categories: MotoGP, Moto2, Moto3
// UUIDs are stable across all seasons — we store them as constants too
model MotoGPCategory {
  id        String @id              // UUID from API e.g. "e8c110ad-..."
  name      String                  // "MotoGP™" | "Moto2™" | "Moto3™"
  legacyId  Int                     // 3 = MotoGP, 2 = Moto2, 1 = Moto3

  riders       MotoGPRider[]
  events       MotoGPEvent[]
  riderStandings      MotoGPRiderStanding[]
  constructorStandings MotoGPConstructorStanding[]
  teamStandings        MotoGPTeamStanding[]

  @@map("motogp_categories")
}

model MotoGPRider {
  id          String  @id           // riders_api_uuid from API
  fullName    String
  firstName   String?
  lastName    String?
  nationality String?               // country.iso e.g. "ES"
  birthDate   String?               // "1993-02-17"
  birthCity   String?
  number      Int?                  // current bike number
  legacyId    Int?                  // for building photo URLs
  categoryId  String                // which class they primarily ride in
  photoUrl    String?                 // constructed from legacyId e.g. "https
  category    MotoGPCategory @relation(fields: [categoryId], references: [id])

  results     MotoGPResult[]
  standings   MotoGPRiderStanding[]

  @@map("motogp_riders")
}

model MotoGPTeam {
  id       String @id               // UUID from API
  name     String
  legacyId Int?
  color    String?                  // team color from career[].team.color
  textColor String?

  results   MotoGPResult[]
  standings MotoGPTeamStanding[]

  @@map("motogp_teams")
}

model MotoGPConstructor {
  id       String @id               // UUID from API
  name     String                   // "Ducati" | "KTM" | "Honda" | "Yamaha" | "Aprilia"
  legacyId Int?

  results   MotoGPResult[]
  standings MotoGPConstructorStanding[]

  @@map("motogp_constructors")
}

model MotoGPCircuit {
  id       String @id               // UUID from API  e.g. "abc123..."
  name     String                   // "Circuit Ricardo Tormo"
  place    String?                  // city/place
  nation   String?                  // country short code e.g. "SPA"
  legacyId Int?

  events MotoGPEvent[]

  @@map("motogp_circuits")
}

// ─── Season Data ─────────────────────────────────────────────────────────────

model MotoGPSeason {
  id      String @id               // UUID from API
  year    Int    @unique
  current Boolean @default(false)

  events               MotoGPEvent[]
  riderStandings       MotoGPRiderStanding[]
  constructorStandings MotoGPConstructorStanding[]
  teamStandings        MotoGPTeamStanding[]

  @@map("motogp_seasons")
}

model MotoGPEvent {
  id            String  @id         // UUID from API
  seasonId      String
  season        MotoGPSeason   @relation(fields: [seasonId], references: [id])
  categoryId    String
  category      MotoGPCategory @relation(fields: [categoryId], references: [id])
  circuitId     String?
  circuit       MotoGPCircuit? @relation(fields: [circuitId], references: [id])

  name          String              // "GRAND PRIX OF THAILAND"
  shortName     String?             // "THA"
  sponsoredName String?             // "PT Grand Prix of Thailand"
  dateStart     String              // "2025-02-28"
  dateEnd       String              // "2025-03-02"
  status        String?             // "FINISHED"
  isTest        Boolean @default(false)

  sessions MotoGPSession[]

  @@unique([seasonId, categoryId, shortName])
  @@index([seasonId, categoryId])
  @@map("motogp_events")
}

model MotoGPSession {
  id        String  @id             // UUID from API
  eventId   String
  event     MotoGPEvent @relation(fields: [eventId], references: [id], onDelete: Cascade)

  // FP | PR | Q | SPR | WUP | RAC
  // Q appears twice (Q1 + Q2) — differentiated by sessionNumber
  type          String
  sessionNumber Int     @default(1) // 1 or 2 for Q1/Q2, FP1/FP2 etc
  date          String?             // "2025-11-16T14:00:00+00:00"
  status        String?             // "FINISHED"

  // Weather/conditions
  trackCondition String?
  airTemp        String?
  humidity       String?
  groundTemp     String?
  weather        String?

  results MotoGPResult[]

  @@index([eventId, type])
  @@map("motogp_sessions")
}

model MotoGPResult {
  id            String @id          // UUID from API classification row
  sessionId     String
  session       MotoGPSession  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  riderId       String
  rider         MotoGPRider    @relation(fields: [riderId], references: [id])
  teamId        String?
  team          MotoGPTeam?    @relation(fields: [teamId], references: [id])
  constructorId String?
  constructor   MotoGPConstructor? @relation(fields: [constructorId], references: [id])

  position      Int?
  status        String?             // "INSTND" | "DNF" | "DNS" etc
  points        Float?
  time          String?             // "40:52.458" for race, null for DNF
  gapFirst      String?             // gap to leader
  gapLap        Int?                // laps behind leader (if >1 lap down)
  averageSpeed  Float?              // km/h — race/sprint only
  totalLaps     Int?

  // FP + Qualifying only
  bestLapTime   String?             // "01:28.809"
  bestLapNumber Int?
  topSpeed      Float?              // km/h
  gapPrev       String?             // gap to rider ahead — quali only

  createdAt DateTime @default(now())

  @@unique([sessionId, riderId])
  @@index([sessionId])
  @@index([riderId])
  @@map("motogp_results")
}

// ─── Standings ───────────────────────────────────────────────────────────────

model MotoGPRiderStanding {
  id         Int    @id @default(autoincrement())
  seasonId   String
  season     MotoGPSeason   @relation(fields: [seasonId], references: [id])
  categoryId String
  category   MotoGPCategory @relation(fields: [categoryId], references: [id])
  riderId    String
  rider      MotoGPRider    @relation(fields: [riderId], references: [id])

  position      Int
  points        Float
  raceWins      Int    @default(0)
  podiums       Int    @default(0)
  sprintWins    Int    @default(0)
  sprintPodiums Int    @default(0)

  // team + constructor stored as strings (denormalised for query speed)
  teamName      String?
  constructorName String?

  updatedAt DateTime @updatedAt

  @@unique([seasonId, categoryId, riderId])
  @@index([seasonId, categoryId, position])
  @@map("motogp_rider_standings")
}

// Constructor standings: grouped by constructor name per season/category
// (API returns per-rider rows — we aggregate in sync service)
model MotoGPConstructorStanding {
  id           Int    @id @default(autoincrement())
  seasonId     String
  season       MotoGPSeason   @relation(fields: [seasonId], references: [id])
  categoryId   String
  category     MotoGPCategory @relation(fields: [categoryId], references: [id])
  constructorId String
  constructor  MotoGPConstructor @relation(fields: [constructorId], references: [id])

  position  Int
  points    Float
  wins      Int   @default(0)

  updatedAt DateTime @updatedAt

  @@unique([seasonId, categoryId, constructorId])
  @@index([seasonId, categoryId, position])
  @@map("motogp_constructor_standings")
}

model MotoGPTeamStanding {
  id         Int    @id @default(autoincrement())
  seasonId   String
  season     MotoGPSeason   @relation(fields: [seasonId], references: [id])
  categoryId String
  category   MotoGPCategory @relation(fields: [categoryId], references: [id])
  teamId     String
  team       MotoGPTeam @relation(fields: [teamId], references: [id])

  position  Int
  points    Float
  wins      Int   @default(0)

  updatedAt DateTime @updatedAt

  @@unique([seasonId, categoryId, teamId])
  @@index([seasonId, categoryId, position])
  @@map("motogp_team_standings")
}

// ─── Football Reference Data ─────────────────────────────────────────────────

// Competition = a league or tournament (PL, CL, PD, WC …)
// type: "LEAGUE" | "CUP" | "TOURNAMENT"
// plan: "TIER_ONE" competitions are Phase 1; others seeded as Coming Soon
model FootballCompetition {
  id          Int     @id @default(autoincrement())
  code        String  @unique   // "PL" | "CL" | "PD" | "WC" | "BL1" etc
  name        String            // "Premier League"
  shortName   String?           // "PL"
  emblemUrl   String?
  country     String?           // "England" | null for international
  countryCode String?           // "ENG" | "ESP" | null
  type        String            // "LEAGUE" | "CUP" | "TOURNAMENT"
  plan        String            // "TIER_ONE" = Phase 1 active; "TIER_TWO" = Coming Soon
  isCurrent   Boolean @default(false)

  seasons  FootballSeason[]

  @@map("football_competitions")
}

// One row per competition-year.
// startDate / endDate from API. currentMatchday updated on each sync.
model FootballSeason {
  id              Int     @id       // API integer id
  competitionId   Int
  competition     FootballCompetition @relation(fields: [competitionId], references: [id])
  year            Int               // 2024 (represents 2024/25 or just 2024 for WC)
  startDate       String?           // "2024-08-16"
  endDate         String?           // "2025-05-25"
  currentMatchday Int?
  isCurrent       Boolean @default(false)

  standings FootballStanding[]
  matches   FootballMatch[]
  scorers   FootballScorer[]

  @@unique([competitionId, year])
  @@index([competitionId, isCurrent])
  @@map("football_seasons")
}

// Club/national team — reused across competitions and seasons
model FootballTeam {
  id          Int     @id       // API integer id
  name        String            // "Manchester City FC"
  shortName   String?           // "Man City"
  tla         String?           // "MCI"
  crestUrl    String?
  country     String?
  founded     Int?
  venue       String?
  website     String?
  colors      String?           // "sky blue / white"

  players      FootballPlayer[]
  homeMatches  FootballMatch[]   @relation("HomeTeam")
  awayMatches  FootballMatch[]   @relation("AwayTeam")
  standings    FootballStanding[]
  scorers      FootballScorer[]

  @@map("football_teams")
}

// Player — full profile, linked to a team (current squad assignment)
model FootballPlayer {
  id            Int     @id       // API integer id
  teamId        Int?
  team          FootballTeam? @relation(fields: [teamId], references: [id])
  name          String
  firstName     String?
  lastName      String?
  dateOfBirth   String?           // "1990-05-24"
  nationality   String?
  position      String?           // "Goalkeeper" | "Defence" | "Midfield" | "Offence"
  shirtNumber   Int?
  marketValue   String?           // if available
  photoUrl      String?           // constructed or from API

  matchEvents FootballMatchEvent[]
  scorerRows  FootballScorer[]

  @@index([teamId])
  @@map("football_players")
}

// ─── Season Data ─────────────────────────────────────────────────────────────

// One row per team per competition-season.
// group is null for leagues; "A" | "B" … for WC/CL group stage.
// stage: "GROUP_STAGE" | "FINAL" etc — used for WC knockout rounds.
model FootballStanding {
  id          Int    @id @default(autoincrement())
  seasonId    Int
  season      FootballSeason @relation(fields: [seasonId], references: [id])
  teamId      Int
  team        FootballTeam   @relation(fields: [teamId], references: [id])

  stage       String  @default("GROUP_STAGE")  // "GROUP_STAGE" for leagues too
  group       String?                           // "A" … "H" for WC/CL groups; null for PL/PD
  type        String  @default("TOTAL")         // "TOTAL" | "HOME" | "AWAY"

  position    Int
  playedGames Int     @default(0)
  won         Int     @default(0)
  draw        Int     @default(0)
  lost        Int     @default(0)
  points      Int     @default(0)
  goalsFor    Int     @default(0)
  goalsAgainst Int    @default(0)
  goalDiff    Int     @default(0)
  form        String?                           // "W,W,D,L,W"

  updatedAt DateTime @updatedAt

  @@unique([seasonId, teamId, stage, group, type])
  @@index([seasonId, stage, group, position])
  @@map("football_standings")
}

// A single fixture or result.
// stage: "GROUP_STAGE" | "ROUND_OF_16" | "QUARTER_FINALS" | "SEMI_FINALS" | "FINAL"
//        For leagues: "REGULAR_SEASON"
// status: "TIMED" | "SCHEDULED" | "LIVE" | "IN_PLAY" | "PAUSED" | "FINISHED" | "POSTPONED" etc
model FootballMatch {
  id            Int    @id       // API integer id
  seasonId      Int
  season        FootballSeason @relation(fields: [seasonId], references: [id])
  homeTeamId    Int
  homeTeam      FootballTeam   @relation("HomeTeam", fields: [homeTeamId], references: [id])
  awayTeamId    Int
  awayTeam      FootballTeam   @relation("AwayTeam", fields: [awayTeamId], references: [id])

  utcDate       String                        // "2024-08-17T14:00:00Z"
  status        String                        // "TIMED" | "FINISHED" etc
  matchday      Int?
  stage         String  @default("REGULAR_SEASON")
  group         String?                       // WC/CL group "A"…"H"
  lastUpdated   String?

  // Scores — stored flat for fast access
  scoreFullHome    Int?
  scoreFullAway    Int?
  scoreHalfHome    Int?
  scoreHalfAway    Int?
  scoreExtraHome   Int?
  scoreExtraAway   Int?
  scorePenHome     Int?
  scorePenAway     Int?
  winner           String?                    // "HOME_TEAM" | "AWAY_TEAM" | "DRAW"

  // Referee
  refereeId     Int?
  refereeName   String?

  events  FootballMatchEvent[]

  @@index([seasonId, matchday])
  @@index([seasonId, stage])
  @@index([homeTeamId])
  @@index([awayTeamId])
  @@map("football_matches")
}

// Goals, cards, substitutions — one row per event per match
// type: "GOAL" | "OWN_GOAL" | "PENALTY" | "YELLOW_CARD" | "RED_CARD"
//       "YELLOW_RED_CARD" | "SUBSTITUTION"
model FootballMatchEvent {
  id          Int    @id @default(autoincrement())
  matchId     Int
  match       FootballMatch  @relation(fields: [matchId], references: [id], onDelete: Cascade)
  playerId    Int?
  player      FootballPlayer? @relation(fields: [playerId], references: [id])

  minute      Int?
  extraMinute Int?
  type        String          // "GOAL" | "YELLOW_CARD" | "SUBSTITUTION" etc
  detail      String?         // "Normal Goal" | "Penalty" | "Own Goal"
  teamSide    String?         // "HOME" | "AWAY"
  playerName  String?         // denormalised — player may not be in DB yet
  assistName  String?         // for goals

  @@index([matchId])
  @@index([playerId])
  @@map("football_match_events")
}

// Top scorers snapshot — refreshed from /competitions/{code}/scorers each sync
model FootballScorer {
  id          Int    @id @default(autoincrement())
  seasonId    Int
  season      FootballSeason @relation(fields: [seasonId], references: [id])
  playerId    Int
  player      FootballPlayer @relation(fields: [playerId], references: [id])
  teamId      Int?
  team        FootballTeam?  @relation(fields: [teamId], references: [id])

  position    Int?
  goals       Int     @default(0)
  assists     Int?
  penalties   Int?
  playedMatches Int?

  updatedAt DateTime @updatedAt

  @@unique([seasonId, playerId])
  @@index([seasonId, goals])
  @@map("football_scorers")
}